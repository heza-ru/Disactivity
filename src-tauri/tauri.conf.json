{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "disactivity",
  "version": "0.1.0",
  "identifier": "com.javiw.disactivity",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "disactivity",
        "width": 650,
        "height": 800,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "windowEffects": {
          "effects": ["mica"]
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/holasoyender/disactivity/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhFODk3N0RFQjM0MjJDMzUKUldRMUxFS3ozbmVKamsxM2xvUHN4ZDJvbUxRb29oRGVSUURtdDhpOHFQZ0xOMzhNSk00YVVtRnUK"
    }
  }
}
