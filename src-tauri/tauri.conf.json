{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Disactivity",
  "version": "0.1.0-1",
  "identifier": "com.holasoyender.disactivity",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Disactivity",
        "width": 650,
        "height": 800,
        "minWidth": 600,
        "minHeight": 720,
        "decorations": false,
        "transparent": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "publisher": "heza-ru",
    "copyright": "Copyright © 2026 heza-ru. Based on Disactivity (MIT) by holasoyender",
    "shortDescription": "Discord Activity Simulator",
    "longDescription": "Disactivity allows you to simulate game activity on Discord by running fake game processes that Discord can detect.",
    "category": "Utility",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/heza-ru/Disactivity/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU5Mjg3QjRDOTgyNzZEOEYKUldTUGJTZVlUSHNvV1ljb3c5VGI0V0R1VEtOb2NRL1VSdi9IaUJMRERJM3RxU0lGMGlSY2wzeVgK"
    }
  }
}
